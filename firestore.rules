rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol_id == 'admin';
    }

    // Perfil propio del usuario
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      // Agenda privada del usuario
      match /contacts/{contactId} {
        allow read, delete: if isOwner(userId);

        // Crear contacto manual/importado dentro de la agenda del usuario autenticado
        allow create: if isOwner(userId) &&
          request.resource.data.owner_uid == request.auth.uid;

        // Editar solo contactos ya pertenecientes al mismo usuario
        allow update: if isOwner(userId) &&
          resource.data.owner_uid == request.auth.uid &&
          request.resource.data.owner_uid == resource.data.owner_uid;
      }
    }

    match /rol/{roleId} {
      allow read: if isSignedIn();
    }

    match /menus/{menuId} {
      allow read: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
